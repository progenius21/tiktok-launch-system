# Stripe - get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe webhook signing secret - get from https://dashboard.stripe.com/webhooks
# When testing locally: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend - get from https://resend.com/api-keys
RESEND_API_KEY=re_...

# The email address Resend sends from (must be verified in your Resend account)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# The public URL of your site (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://tiklaunch.io

# Supabase - get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic - get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional analytics pixels
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
